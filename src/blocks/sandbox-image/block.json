{
	"$schema": "https://schemas.wp.org/wp/5.8/block.json",
	"apiVersion": 2,
	"name": "r3-id-documentation/image",
	"version": "0.1.0",
	"title": "<Image> Component - Playground",
	"category": "r3-id-documentation-pattern-category",
	"icon": "format-image",
	"description": "This block is used to explore and adjust the parameters sent to the <Image> Component.",
	"example": {},
	"attributes": {
		"canEditImage": {
			"type": "boolean"
		},
		"debug": {
			"type": "boolean"
		},
		"tag": {
			"type": "string",
			"enum": [ "img", "picture", "figure" ]
		},
		"size": {
			"type": "string"
		},
		"altSource": {
			"type": "string"
		},
		"mediaId": {
			"type": "string"
		},
		"className": {
			"type": "string"
		},
		"canEditFocalPoint": {
			"type": "boolean"
		},
		"focalPoint": {
			"type": "string"
		},
		"label": {
			"type": "string"
		},
		"instructions": {
			"type": "string"
		},
		"labels": {
			"type": "array"
		}
	},
	"supports": {
		"html": false
	},
	"textdomain": "r3-id-documentation",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
